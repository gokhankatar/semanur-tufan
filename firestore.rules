rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Dergiler - Herkes okuyabilir, sadece admin yazabilir. Görüntülenme sayacı herkes güncelleyebilir.
    match /journals/{journalId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['view_count']);
    }
    match /bloglar/{blogId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    // Çalışmalar - Herkes okuyabilir, sadece admin yazabilir
    match /works/{workId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    // Yapılacaklar - Sadece admin görür ve yazar
    match /todo/{todoId} {
      allow read, write: if request.auth != null;
    }
    // Kullanıcı profilleri - Sadece kendi profili
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Site ayarları - Herkes okuyabilir, sadece admin yazabilir
    match /site-settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Aboneler - Herkes abone olabilir (create), sadece admin görür/siler
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
